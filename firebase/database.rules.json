{
  "rules": {
    ".read": false,
    ".write": false,
    "roles": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('roles').child(auth.uid).val() === 'admin')",
        ".write": "auth != null && root.child('roles').child(auth.uid).val() === 'admin'",
        ".validate": "newData.isString() && (newData.val() === 'admin' || newData.val() === 'operator' || newData.val() === 'auditor')"
      }
    },
    "stores": {
      ".read": "auth != null && root.child('roles').child(auth.uid).exists()",
      ".write": "auth != null && root.child('roles').child(auth.uid).val() === 'admin'"
    },
    "products": {
      ".read": "auth != null && root.child('roles').child(auth.uid).exists()",
      "$id": {
        ".write": "auth != null && (root.child('roles').child(auth.uid).val() === 'admin' || root.child('roles').child(auth.uid).val() === 'operator')",
        ".validate": "newData.hasChildren(['name','sku','status']) && newData.child('name').isString() && newData.child('name').val().length > 0 && newData.child('sku').isString() && newData.child('sku').val().length > 0 && (newData.child('status').val() === 'active' || newData.child('status').val() === 'inactive')"
      }
    },
    "tags": {
      ".read": "auth != null && root.child('roles').child(auth.uid).exists()",
      "$id": {
        ".write": "auth != null && (root.child('roles').child(auth.uid).val() === 'admin' || root.child('roles').child(auth.uid).val() === 'operator')",
        ".validate": "newData.hasChildren(['serial','productId','sku','storeId','zoneId','status','qrPayload','createdAt','createdBy'])"
      }
    },
    "cameras": {
      ".read": "auth != null && root.child('roles').child(auth.uid).exists()",
      "$id": {
        ".write": "auth != null && root.child('roles').child(auth.uid).val() === 'admin'",
        ".validate": "newData.hasChildren(['cameraId','name','storeId','area','protocol','status']) && !newData.child('rtspUrl').exists() && !newData.child('password').exists() && !newData.child('token').exists() && !newData.child('inviteCode').exists() && !newData.child('shareUrl').exists() && !newData.child('rawQrPayload').exists()"
      }
    },
    "cameraBridges": {
      ".read": "auth != null && root.child('roles').child(auth.uid).exists()",
      ".write": "auth != null && (root.child('roles').child(auth.uid).val() === 'admin' || root.child('roles').child(auth.uid).val() === 'operator')"
    },
    "integrations": {
      ".read": "auth != null && root.child('roles').child(auth.uid).exists()",
      "$provider": {
        ".write": "auth != null && root.child('roles').child(auth.uid).val() === 'admin'",
        ".validate": "newData.hasChildren(['provider','accountEmail','status','passwordStored']) && newData.child('accountEmail').isString() && newData.child('passwordStored').val() === false && !newData.child('password').exists() && !newData.child('token').exists() && !newData.child('inviteCode').exists()"
      }
    },
    "sessions": {
      ".read": "auth != null && root.child('roles').child(auth.uid).exists()",
      ".write": "auth != null && (root.child('roles').child(auth.uid).val() === 'admin' || root.child('roles').child(auth.uid).val() === 'operator')"
    },
    "events": {
      ".read": "auth != null && root.child('roles').child(auth.uid).exists()",
      "$id": {
        ".write": "auth != null && (root.child('roles').child(auth.uid).val() === 'admin' || root.child('roles').child(auth.uid).val() === 'operator')",
        ".validate": "newData.hasChildren(['type','storeId','createdAt'])"
      }
    },
    "occurrences": {
      ".read": "auth != null && (root.child('roles').child(auth.uid).val() === 'admin' || root.child('roles').child(auth.uid).val() === 'auditor')",
      "$id": {
        ".write": "auth != null && (root.child('roles').child(auth.uid).val() === 'admin' || root.child('roles').child(auth.uid).val() === 'auditor' || (root.child('roles').child(auth.uid).val() === 'operator' && !data.exists() && newData.child('status').val() === 'pending'))"
      }
    },
    "auditLogs": {
      ".read": "auth != null && root.child('roles').child(auth.uid).val() === 'admin'",
      ".write": "auth != null && root.child('roles').child(auth.uid).exists()"
    },
    "zones": {
      ".read": "auth != null && root.child('roles').child(auth.uid).exists()",
      "$storeId": {
        "$cameraId": {
          "$zoneId": {
            ".write": "auth != null && (root.child('roles').child(auth.uid).val() === 'admin' || root.child('roles').child(auth.uid).val() === 'operator')",
            ".validate": "newData.hasChildren(['zoneId','storeId','cameraId','left','top','right','bottom','updatedAt']) && newData.child('left').isNumber() && newData.child('top').isNumber() && newData.child('right').isNumber() && newData.child('bottom').isNumber()"
          }
        }
      }
    },
    "carts": {
      ".read": "auth != null && root.child('roles').child(auth.uid).exists()",
      "$storeId": {
        "$sessionId": {
          "$personId": {
            "$serial": {
              ".write": "auth != null && (root.child('roles').child(auth.uid).val() === 'admin' || root.child('roles').child(auth.uid).val() === 'operator')",
              ".validate": "!newData.exists() || newData.hasChildren(['serial','status','updatedAt'])"
            }
          }
        }
      }
    },
    "visionPilots": {
      ".read": "auth != null && root.child('roles').child(auth.uid).exists()",
      "$pilotId": {
        ".write": "auth != null && (root.child('roles').child(auth.uid).val() === 'admin' || root.child('roles').child(auth.uid).val() === 'operator')",
        ".validate": "newData.hasChildren(['pilotId','storeId','cameraId','status','lastSeenAt'])"
      }
    },
    "tagStates": {
      ".read": "auth != null && root.child('roles').child(auth.uid).exists()",
      "$serial": {
        ".write": "auth != null && (root.child('roles').child(auth.uid).val() === 'admin' || root.child('roles').child(auth.uid).val() === 'operator')"
      }
    },
    "cameraLive": {
      ".read": "auth != null && root.child('roles').child(auth.uid).exists()",
      "$storeId": {
        "$cameraId": {
          ".write": "auth != null && (root.child('roles').child(auth.uid).val() === 'admin' || root.child('roles').child(auth.uid).val() === 'operator')",
          ".validate": "newData.hasChildren(['storeId','cameraId','status','updatedAt']) && newData.child('storeId').val() === $storeId && newData.child('cameraId').val() === $cameraId && (!newData.child('frameDataUrl').exists() || (newData.child('frameDataUrl').isString() && newData.child('frameDataUrl').val().length < 900000))"
        }
      }
    }
  }
}
